# MEMBRA Protocol — Environment Variables
# Copy to .env and fill in before running scripts.

# ── Solana cluster ──────────────────────────────────────────────────
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# ── Program IDs (set after anchor keys sync) ────────────────────────
MEMBRA_IDO_PROGRAM_ID=
MEMBRA_REBASE_PROGRAM_ID=
MEMBRA_REWARDS_PROGRAM_ID=
MEMBRA_GOVERNANCE_PROGRAM_ID=

# ── Token mints ─────────────────────────────────────────────────────
TOKEN_MINT=
PAYMENT_MINT=          # USDC mint (devnet: Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr)
REWARD_MINT=

# ── PDAs (derived; fill in after initialization) ─────────────────────
IDO_CONFIG_PDA=
REBASE_STATE_PDA=
REWARDS_POOL_PDA=
GOVERNANCE_CONFIG_PDA=

# ── Governance ──────────────────────────────────────────────────────
SIGNERS=keys/signer1.json,keys/signer2.json,keys/signer3.json
THRESHOLD=2
TIMELOCK_SECONDS=86400        # 24h for devnet; use 172800+ for mainnet
EXECUTION_WINDOW=172800        # 48h
TREASURY=

# ── Oracle ──────────────────────────────────────────────────────────
# Pyth devnet price feeds: https://pyth.network/developers/price-feed-ids
PYTH_PRICE_FEED=              # e.g. SOL/USD feed pubkey on devnet

# ── Rebase params ───────────────────────────────────────────────────
TARGET_PRICE_USD6=550000       # $0.55
MONITORING_BAND_MIN_USD6=100000  # $0.10
MONITORING_BAND_MAX_USD6=1000000 # $1.00
MAX_POSITIVE_REBASE_BPS=500    # +5% per epoch
MAX_NEGATIVE_REBASE_BPS=-500   # -5% per epoch
REBASE_COEFFICIENT_BPS=5000    # 50% dampening
MIN_EPOCH_SECONDS=86400        # 24h minimum between rebases
STALE_PRICE_THRESHOLD=3600     # 1h oracle staleness limit
VOLATILITY_CIRCUIT_BREAKER_BPS=2000  # 20% intra-epoch move trips breaker

# ── IDO params ──────────────────────────────────────────────────────
TOKEN_PRICE_USD6=100000         # $0.10 per token
HARD_CAP_TOKENS=               # in base units (6 decimals)
MIN_PURCHASE_TOKENS=10000000   # 10 tokens
MAX_PURCHASE_TOKENS=           # per wallet
IDO_START_TS=                  # Unix timestamp
IDO_END_TS=
IDO_CLAIM_START_TS=
IDO_UNSOLD_BURN=true

# ── Rewards ─────────────────────────────────────────────────────────
EMISSION_RATE_PER_SECOND=      # tokens/second (6 decimals)
REWARD_POOL_CAP=               # max tokens in reward vault
EARLY_EXIT_PENALTY_BPS=1000    # 10%
PENALTY_DESTINATION=           # treasury pubkey

# ── Scripts ─────────────────────────────────────────────────────────
EXECUTE=false                  # set to true to actually execute scripts
CONFIRM=                       # set to yes for destructive operations
SIMULATED_PRICE_USD6=600000    # $0.60 for simulate_rebase.ts dry runs
