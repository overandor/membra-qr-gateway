{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/config",
    "rootDir": "config",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["config/**/*.ts"],
  "exclude": ["node_modules", "dist", "protocol"]
}
