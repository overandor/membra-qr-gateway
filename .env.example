# MEMBRA QR Gateway — Production Environment Template
# Copy to .env and fill in values. Never commit .env to Git.

# ── Runtime ──────────────────────────────────────────────────────────────────
ENV=development
PORT=7860
APP_BASE_URL=http://localhost:7860
DB_PATH=./data/membra_qr_gateway.sqlite3

# ── Security ─────────────────────────────────────────────────────────────────
# Required in production. Falls back to permissive mode if omitted.
MEMBRA_EVENT_SECRET=

# Admin API key for sensitive endpoints (rebase trigger, etc.)
# MUST be set in production. Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# CORS origin allowlist. Comma-separated. Use exact domains in production.
# Example: CORS_ORIGINS=https://app.membra.network,https://dashboard.membra.network
CORS_ORIGINS=*

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Membra Protocol ──────────────────────────────────────────────────────────
PUBLIC_SUPPORT_WALLET=
