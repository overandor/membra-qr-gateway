# ─────────────────────────────────────────────────────────────────────────────
# MEMBRA QR Gateway — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# See security/keys/README_DO_NOT_COMMIT_KEYS.md for key management guidance.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file
DB_PATH=/app/data/membra.sqlite3

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — minimum 32 characters, cryptographically random
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-min-32-chars

# Salt for hashing API keys at rest
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY_SALT=change-me-in-production

# Admin API key for protected management endpoints
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me

# ── Membra Events ─────────────────────────────────────────────────────────────
# Webhook signing secret from Membra dashboard
MEMBRA_EVENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Stripe test/live secret key — sk_test_... or sk_live_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook endpoint signing secret — whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for MEMBRA subscription/product
STRIPE_PRICE_ID=price_...

# ── Solana / Web3 ─────────────────────────────────────────────────────────────
# Solana RPC endpoint
# Options:
#   Local:   http://127.0.0.1:8899
#   Devnet:  https://api.devnet.solana.com
#   Mainnet: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# API base URL as seen from the browser (used by Vite at build time)
VITE_API_URL=http://localhost:7860

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on
PORT=7860

# Number of uvicorn workers (production: match CPU count)
WORKERS=2
