# ─────────────────────────────────────────────────────────────────────────────
# MEMBRA QR Gateway — Production Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# This file shows the PATTERN for production values.
# Actual secrets are stored in your secret manager, NOT here.
#
# Secret storage options (pick one):
#   - GitHub Actions Secrets (for CI/CD)
#   - HashiCorp Vault
#   - AWS Secrets Manager
#   - Infisical / Doppler
#   - Host-level /etc/membra/.env (chmod 600, owned by membra user)
#
# NEVER commit actual production secrets to this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Production: persistent volume mount path
DB_PATH=/app/data/membra.sqlite3

# ── Authentication ────────────────────────────────────────────────────────────
# Production: 64-hex-char random secret, rotated quarterly
# Pattern: [64 hex characters]
JWT_SECRET=<64-hex-char-random-secret-from-vault>

# Production: 64-hex-char random salt, rotated annually
API_KEY_SALT=<64-hex-char-random-salt-from-vault>

# Production: 32-char URL-safe token, rotated quarterly
ADMIN_API_KEY=<32-char-url-safe-token-from-vault>

# ── Membra Events ─────────────────────────────────────────────────────────────
# Production: from Membra production dashboard settings
MEMBRA_EVENT_SECRET=<membra-production-event-secret>

# ── Stripe ───────────────────────────────────────────────────────────────────
# Production: LIVE keys (sk_live_...) from Stripe dashboard
STRIPE_SECRET_KEY=sk_live_<your-live-secret-key>

# Production: from Stripe webhook endpoint configuration
STRIPE_WEBHOOK_SECRET=whsec_<your-live-webhook-secret>

# Production: live Price ID from Stripe product catalog
STRIPE_PRICE_ID=price_<your-live-price-id>

# ── Solana / Web3 ─────────────────────────────────────────────────────────────
# Production: mainnet RPC (use a paid RPC for reliability)
# Recommended: Helius, QuickNode, or Alchemy
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<your-api-key>

# ── Logging ───────────────────────────────────────────────────────────────────
# Production: WARNING or INFO (avoid DEBUG — leaks sensitive data)
LOG_LEVEL=WARNING

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: only your production domain(s)
CORS_ORIGINS=https://app.membra.io,https://www.membra.io

# ── Frontend ──────────────────────────────────────────────────────────────────
# Production: your actual API domain (used at build time only)
VITE_API_URL=https://api.membra.io

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7860

# Production: match CPU core count (2 vCPU → 4 workers)
WORKERS=4
